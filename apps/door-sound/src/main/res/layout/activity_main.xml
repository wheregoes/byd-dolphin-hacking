<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF0A0A0F"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Door Sound"
                android:textColor="#FFE0E0E0"
                android:textSize="26sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.05" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Custom sounds for your BYD"
                android:textColor="#FF9E9E9E"
                android:textSize="13sp"
                android:fontFamily="sans-serif-light"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Master Toggle -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/card_background_accent"
            android:paddingLeft="20dp"
            android:paddingRight="20dp"
            android:paddingTop="18dp"
            android:paddingBottom="18dp"
            android:layout_marginBottom="32dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/enabled"
                    android:textColor="#FFE0E0E0"
                    android:textSize="17sp"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Listen for door events"
                    android:textColor="#FF9E9E9E"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-light"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <Switch
                android:id="@+id/switch_enabled"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:track="@drawable/switch_track"
                android:thumb="@drawable/switch_thumb" />
        </LinearLayout>

        <!-- Door Open Sound -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:paddingLeft="20dp"
            android:paddingRight="20dp"
            android:paddingTop="18dp"
            android:paddingBottom="18dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/door_open_sound"
                    android:textColor="#FF00D4AA"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-medium" />

                <Switch
                    android:id="@+id/switch_door_open"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:track="@drawable/switch_track"
                    android:thumb="@drawable/switch_thumb" />
            </LinearLayout>

            <TextView
                android:id="@+id/text_door_open_file"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/no_file_selected"
                android:textColor="#FF9E9E9E"
                android:textSize="12sp"
                android:fontFamily="sans-serif-light"
                android:layout_marginBottom="14dp"
                android:singleLine="true"
                android:ellipsize="middle" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/volume"
                    android:textColor="#FF9E9E9E"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-light"
                    android:layout_marginEnd="10dp" />

                <SeekBar
                    android:id="@+id/seek_door_open_volume"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:progressTint="#FF4A9EFF"
                    android:progressBackgroundTint="#FF2A2A3E"
                    android:thumbTint="#FFFFFFFF"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/text_door_open_volume"
                    android:layout_width="28dp"
                    android:layout_height="wrap_content"
                    android:textColor="#FFE0E0E0"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="center" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_door_open_select"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_weight="1"
                    android:text="@string/select_file"
                    android:textColor="#FF4A9EFF"
                    android:textSize="13sp"
                    android:textAllCaps="false"
                    android:fontFamily="sans-serif-medium"
                    android:background="@drawable/btn_primary"
                    android:layout_marginEnd="10dp" />

                <Button
                    android:id="@+id/btn_door_open_clear"
                    android:layout_width="72dp"
                    android:layout_height="42dp"
                    android:text="@string/clear"
                    android:textColor="#FFFF6B6B"
                    android:textSize="13sp"
                    android:textAllCaps="false"
                    android:fontFamily="sans-serif-medium"
                    android:background="@drawable/btn_clear" />
            </LinearLayout>
        </LinearLayout>

        <!-- Door Close Sound -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:paddingLeft="20dp"
            android:paddingRight="20dp"
            android:paddingTop="18dp"
            android:paddingBottom="18dp"
            android:layout_marginBottom="32dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="14dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/door_close_sound"
                    android:textColor="#FF00D4AA"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-medium" />

                <Switch
                    android:id="@+id/switch_door_close"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:track="@drawable/switch_track"
                    android:thumb="@drawable/switch_thumb" />
            </LinearLayout>

            <TextView
                android:id="@+id/text_door_close_file"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/no_file_selected"
                android:textColor="#FF9E9E9E"
                android:textSize="12sp"
                android:fontFamily="sans-serif-light"
                android:layout_marginBottom="14dp"
                android:singleLine="true"
                android:ellipsize="middle" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/volume"
                    android:textColor="#FF9E9E9E"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-light"
                    android:layout_marginEnd="10dp" />

                <SeekBar
                    android:id="@+id/seek_door_close_volume"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:progressTint="#FF4A9EFF"
                    android:progressBackgroundTint="#FF2A2A3E"
                    android:thumbTint="#FFFFFFFF"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:id="@+id/text_door_close_volume"
                    android:layout_width="28dp"
                    android:layout_height="wrap_content"
                    android:textColor="#FFE0E0E0"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-medium"
                    android:gravity="center" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_door_close_select"
                    android:layout_width="0dp"
                    android:layout_height="42dp"
                    android:layout_weight="1"
                    android:text="@string/select_file"
                    android:textColor="#FF4A9EFF"
                    android:textSize="13sp"
                    android:textAllCaps="false"
                    android:fontFamily="sans-serif-medium"
                    android:background="@drawable/btn_primary"
                    android:layout_marginEnd="10dp" />

                <Button
                    android:id="@+id/btn_door_close_clear"
                    android:layout_width="72dp"
                    android:layout_height="42dp"
                    android:text="@string/clear"
                    android:textColor="#FFFF6B6B"
                    android:textSize="13sp"
                    android:textAllCaps="false"
                    android:fontFamily="sans-serif-medium"
                    android:background="@drawable/btn_clear" />
            </LinearLayout>
        </LinearLayout>

        <!-- Status -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:paddingLeft="20dp"
            android:paddingRight="20dp"
            android:paddingTop="18dp"
            android:paddingBottom="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/service_status"
                android:textColor="#FF00D4AA"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <View
                    android:id="@+id/status_dot"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/status_dot_stopped"
                    android:layout_marginEnd="10dp" />

                <TextView
                    android:id="@+id/text_service_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/status_stopped"
                    android:textColor="#FF9E9E9E"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-light" />
            </LinearLayout>

            <TextView
                android:id="@+id/text_last_event"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FF9E9E9E"
                android:textSize="12sp"
                android:fontFamily="sans-serif-light" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
