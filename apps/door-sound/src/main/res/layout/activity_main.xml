<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF0A0A0F"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Door Sound"
                android:textColor="#FFE0E0E0"
                android:textSize="26sp"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.05" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Custom sounds for your BYD"
                android:textColor="#FF9E9E9E"
                android:textSize="13sp"
                android:fontFamily="sans-serif-light"
                android:layout_marginTop="4dp" />
        </LinearLayout>

        <!-- Tab Bar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/tab_inactive"
            android:padding="3dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:id="@+id/tab_inside"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="@string/tab_inside"
                android:textColor="#FFFFFFFF"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:background="@drawable/tab_active" />

            <TextView
                android:id="@+id/tab_outside"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="@string/tab_outside"
                android:textColor="#FF9E9E9E"
                android:textSize="13sp"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:background="@android:color/transparent" />
        </LinearLayout>

        <!-- Master Toggle -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/card_background_accent"
            android:paddingLeft="20dp"
            android:paddingRight="20dp"
            android:paddingTop="18dp"
            android:paddingBottom="18dp"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/enabled"
                    android:textColor="#FFE0E0E0"
                    android:textSize="17sp"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Listen for door events"
                    android:textColor="#FF9E9E9E"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif-light"
                    android:layout_marginTop="2dp" />
            </LinearLayout>

            <Switch
                android:id="@+id/switch_enabled"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:track="@drawable/switch_track"
                android:thumb="@drawable/switch_thumb" />
        </LinearLayout>

        <!-- ==================== INSIDE SPEAKER CONTENT ==================== -->
        <LinearLayout
            android:id="@+id/content_inside"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="visible">

            <!-- Door Open -->
            <include layout="@layout/card_inside_event"
                android:id="@+id/card_inside_door_open" />

            <!-- Door Close -->
            <include layout="@layout/card_inside_event"
                android:id="@+id/card_inside_door_close" />

            <!-- Lock -->
            <include layout="@layout/card_inside_event"
                android:id="@+id/card_inside_lock" />

            <!-- Unlock -->
            <include layout="@layout/card_inside_event"
                android:id="@+id/card_inside_unlock" />

        </LinearLayout>

        <!-- ==================== OUTSIDE SPEAKER CONTENT ==================== -->
        <LinearLayout
            android:id="@+id/content_outside"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <!-- Door Open -->
            <include layout="@layout/card_outside_event"
                android:id="@+id/card_outside_door_open" />

            <!-- Door Close -->
            <include layout="@layout/card_outside_event"
                android:id="@+id/card_outside_door_close" />

            <!-- Lock -->
            <include layout="@layout/card_outside_event"
                android:id="@+id/card_outside_lock" />

            <!-- Unlock -->
            <include layout="@layout/card_outside_event"
                android:id="@+id/card_outside_unlock" />

        </LinearLayout>

        <!-- Status -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:paddingLeft="20dp"
            android:paddingRight="20dp"
            android:paddingTop="18dp"
            android:paddingBottom="18dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/service_status"
                android:textColor="#FF00D4AA"
                android:textSize="16sp"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <View
                    android:id="@+id/status_dot"
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/status_dot_stopped"
                    android:layout_marginEnd="10dp" />

                <TextView
                    android:id="@+id/text_service_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/status_stopped"
                    android:textColor="#FF9E9E9E"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-light" />
            </LinearLayout>

            <TextView
                android:id="@+id/text_last_event"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FF9E9E9E"
                android:textSize="12sp"
                android:fontFamily="sans-serif-light" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
