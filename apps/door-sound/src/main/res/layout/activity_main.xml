<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF303030"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Enable toggle -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="#FF424242"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/enabled"
                android:textColor="#FFFFFFFF"
                android:textSize="18sp" />

            <Switch
                android:id="@+id/switch_enabled"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- Door Open Sound -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FF424242"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/door_open_sound"
                android:textColor="#FF4FC3F7"
                android:textSize="16sp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/text_door_open_file"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/no_file_selected"
                android:textColor="#FFAAAAAA"
                android:textSize="14sp"
                android:layout_marginBottom="8dp"
                android:singleLine="true"
                android:ellipsize="middle" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_door_open_select"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/select_file"
                    android:layout_marginEnd="8dp" />

                <Button
                    android:id="@+id/btn_door_open_clear"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/clear" />
            </LinearLayout>
        </LinearLayout>

        <!-- Lock Sound -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FF424242"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/lock_sound"
                android:textColor="#FF4FC3F7"
                android:textSize="16sp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/text_lock_file"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/no_file_selected"
                android:textColor="#FFAAAAAA"
                android:textSize="14sp"
                android:layout_marginBottom="8dp"
                android:singleLine="true"
                android:ellipsize="middle" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_lock_select"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/select_file"
                    android:layout_marginEnd="8dp" />

                <Button
                    android:id="@+id/btn_lock_clear"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/clear" />
            </LinearLayout>
        </LinearLayout>

        <!-- Unlock Sound -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FF424242"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/unlock_sound"
                android:textColor="#FF4FC3F7"
                android:textSize="16sp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/text_unlock_file"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/no_file_selected"
                android:textColor="#FFAAAAAA"
                android:textSize="14sp"
                android:layout_marginBottom="8dp"
                android:singleLine="true"
                android:ellipsize="middle" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_unlock_select"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/select_file"
                    android:layout_marginEnd="8dp" />

                <Button
                    android:id="@+id/btn_unlock_clear"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/clear" />
            </LinearLayout>
        </LinearLayout>

        <!-- Status -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FF424242"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/service_status"
                android:textColor="#FF4FC3F7"
                android:textSize="16sp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/text_service_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/status_stopped"
                android:textColor="#FFAAAAAA"
                android:textSize="14sp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:id="@+id/text_last_event"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FFAAAAAA"
                android:textSize="14sp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
