<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/card_background"
    android:paddingLeft="20dp"
    android:paddingRight="20dp"
    android:paddingTop="18dp"
    android:paddingBottom="18dp"
    android:layout_marginBottom="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="14dp">

        <TextView
            android:id="@+id/card_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#FF00D4AA"
            android:textSize="16sp"
            android:fontFamily="sans-serif-medium" />

        <Switch
            android:id="@+id/card_switch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:track="@drawable/switch_track"
            android:thumb="@drawable/switch_thumb" />
    </LinearLayout>

    <TextView
        android:id="@+id/card_file_label"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/no_file_selected"
        android:textColor="#FF9E9E9E"
        android:textSize="12sp"
        android:fontFamily="sans-serif-light"
        android:layout_marginBottom="14dp"
        android:singleLine="true"
        android:ellipsize="middle" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/volume"
            android:textColor="#FF9E9E9E"
            android:textSize="12sp"
            android:fontFamily="sans-serif-light"
            android:layout_marginEnd="10dp" />

        <SeekBar
            android:id="@+id/card_seekbar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:progressTint="#FF4A9EFF"
            android:progressBackgroundTint="#FF2A2A3E"
            android:thumbTint="#FFFFFFFF"
            android:layout_marginEnd="8dp" />

        <TextView
            android:id="@+id/card_volume_label"
            android:layout_width="28dp"
            android:layout_height="wrap_content"
            android:textColor="#FFE0E0E0"
            android:textSize="13sp"
            android:fontFamily="sans-serif-medium"
            android:gravity="center" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <Button
            android:id="@+id/card_btn_select"
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            android:text="@string/select_file"
            android:textColor="#FF4A9EFF"
            android:textSize="13sp"
            android:textAllCaps="false"
            android:fontFamily="sans-serif-medium"
            android:background="@drawable/btn_primary"
            android:layout_marginEnd="10dp" />

        <Button
            android:id="@+id/card_btn_clear"
            android:layout_width="72dp"
            android:layout_height="42dp"
            android:text="@string/clear"
            android:textColor="#FFFF6B6B"
            android:textSize="13sp"
            android:textAllCaps="false"
            android:fontFamily="sans-serif-medium"
            android:background="@drawable/btn_clear" />
    </LinearLayout>
</LinearLayout>
